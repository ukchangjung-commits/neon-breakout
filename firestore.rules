rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 게임 점수 랭킹 — 누구나 읽기/등록 가능, 수정·삭제 불가
    match /scores/{doc} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['name', 'score', 'level', 'when'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 3
        && request.resource.data.score is int
        && request.resource.data.score >= 0 && request.resource.data.score < 100000000
        && request.resource.data.level is int
        && request.resource.data.level >= 1 && request.resource.data.level < 10000
        && request.resource.data.when is string && request.resource.data.when.size() <= 30;
      allow update, delete: if false;
    }
  }
}
